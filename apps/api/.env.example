# SyncSpace API — Environment Variables
# Copy this file to .env and fill in your values.
# For production, set these via your deployment platform (no .env file).

NODE_ENV=development

# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/syncspace

# Security
SESSION_SECRET=bf9acb0300bf51acaa532e8328a5ea99f93364fa889ccf3ce8d9cfc9652da5abe5bce41e461e759691457cc1a3f710b339acc36d540e6d63628564fffaba7646

# Email (free) — sign up at https://brevo.com (300 emails/day free)
# Use your Brevo account email as SMTP_USER and generate an SMTP key in Brevo settings
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# LiveKit — optional for video calls (get keys from LiveKit Cloud or self-hosted)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=
