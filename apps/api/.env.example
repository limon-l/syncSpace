# SyncSpace — Backend (API) environment variables
# Copy this file to `apps/api/.env` and fill in real values.
# All variables are read by `apps/api/src/lib/config.ts`.
# On Render, set these in the service's Environment tab instead of a file.

# Runtime
NODE_ENV=production
PORT=4000

# Allowed CORS origins (comma-separated). MUST include your frontend URL.
# Example (Vercel): https://syncspace.vercel.app
CORS_ORIGIN=https://your-frontend-url.vercel.app
# Public URL of THIS API (used in verification/reset emails).
# Example (Render): https://syncspace-api.onrender.com
APP_URL=https://your-api-url.onrender.com

# MongoDB (MongoDB Atlas free tier: https://mongodb.com/atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/syncspace?retryWrites=true&w=majority

# Session signing secret — generate with: openssl rand -hex 64
SESSION_SECRET=replace-with-a-64-char-random-hex-string

# Email (free): sign up at https://brevo.com (300 emails/day)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login@brevo.com
SMTP_PASS=your-brevo-smtp-key

# LiveKit (free tier: https://livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
