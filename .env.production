# SyncSpace — Production Environment Variables
# Set these in your deployment platform (Render, Fly.io, Docker, etc.)

NODE_ENV=production

# Server
PORT=4000
CORS_ORIGIN=https://your-app.com
APP_URL=https://your-app.com

# MongoDB (use MongoDB Atlas free tier: https://mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/syncspace

# Security
SESSION_SECRET=bf9acb0300bf51acaa532e8328a5ea99f93364fa889ccf3ce8d9cfc9652da5abe5bce41e461e759691457cc1a3f710b339acc36d540e6d63628564fffaba7646

# Email (free) — sign up at https://brevo.com (300 emails/day free)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# LiveKit — sign up at https://livekit.io (free tier available)
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
